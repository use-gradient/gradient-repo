# ─── Gradient v0.1 Environment Configuration ───
#
# QUICK START (local dev):
#   make dev  ← auto-creates Stripe products, derives Clerk JWKS URL,
#                generates + uploads Hetzner SSH key, starts Postgres + NATS + Vault,
#                builds binaries, runs tests + migrations
#
# PRODUCTION:
#   cp .env.example .env  ← then fill in every value below

# ─── Core ───
PORT=6767
ENV=production
# `make dev` starts PostgreSQL via docker compose.
# Production: Supabase, Hetzner Managed DB, or AWS RDS.
DATABASE_URL=postgres://gradient:gradient@localhost:5432/gradient?sslmode=disable
# Must be reachable from Hetzner servers (not localhost in production).
API_URL=https://api.yourdomain.com

# ─── Authentication (Clerk) ───
# 1. https://dashboard.clerk.com → Create application
# 2. API Keys → copy "Secret keys" (starts with sk_live_ or sk_test_)
CLERK_SECRET_KEY=sk_live_xxxxxxxxxxxx
# 3. API Keys → copy "Publishable key" (starts with pk_live_ or pk_test_)
CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxx
# `make dev` auto-derives this from CLERK_SECRET_KEY.
# Format: https://api.clerk.com/v1/jwks (Backend API) or https://your-app.clerk.accounts.dev/.well-known/jwks.json
CLERK_JWKS_URL=
# Legacy fallback — only if your Clerk instance blocks JWKS endpoint.
CLERK_PEM_PUBLIC_KEY=

# ─── JWT Signing ───
# HMAC secret for minting long-lived CLI tokens after Clerk sign-in.
# Generate: openssl rand -hex 32
# `make dev` auto-generates this if empty.
JWT_SECRET=

# ─── Billing (Stripe) ───
# 1. https://dashboard.stripe.com → Developers → API Keys → Secret key
# `make dev` auto-creates 3 metered products + prices on first run.
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxx
# Auto-filled by `make dev`:
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SMALL_ID=
STRIPE_PRICE_MEDIUM_ID=
STRIPE_PRICE_LARGE_ID=

# ─── Hetzner Cloud ───
# 1. https://console.hetzner.cloud → Create project
# 2. Security → API Tokens → Generate (Read & Write)
# `make dev` auto-generates SSH key (~/.ssh/gradient-key) and uploads it.
# Locations: fsn1 (Falkenstein DE), nbg1 (Nuremberg DE), hel1 (Helsinki FI),
#            ash (Ashburn US), hil (Hillsboro US)
HETZNER_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HETZNER_LOCATION=fsn1
# Auto-filled by `make dev`:
HETZNER_SSH_KEY_IDS=
HETZNER_SSH_PRIVATE_KEY=
# Optional — create in Hetzner Console for firewall/network isolation:
HETZNER_FIREWALL_ID=
HETZNER_NETWORK_ID=
# Custom Hetzner snapshot ID (from scripts/build-hetzner-snapshot.sh).
# Empty = stock ubuntu-24.04 (slower cold boot).
HETZNER_IMAGE_ID=

# ─── Platform Default Container Registry ───
# Used for orgs that don't configure their own registry.
# Enterprise orgs override per-org via: gc org registry set --url <url>
#
# Options:
#   GitHub Container Registry: ghcr.io/yourorg/gradient-envs
#     → https://github.com/settings/tokens → New PAT with write:packages
#   Docker Hub: docker.io/yourorg/gradient-envs
#     → https://hub.docker.com/settings/security → New Access Token
#   Self-hosted (Harbor, etc.): registry.yourdomain.com/gradient-envs
REGISTRY_URL=ghcr.io/yourorg/gradient-envs
REGISTRY_USER=youruser
REGISTRY_PASS=ghp_xxxxxxxxxxxx

# ─── Warm Pool ───
# Pre-boots servers for ~5-15s assignment vs 2-6min cold boot.
# Each CX22 ≈ $0.035/hr. Hard cap is 8.
#
# COST:  3 servers = ~$2.50/day = ~$75/month (default)
#        0 servers = disabled, all boots are cold
WARM_POOL_DEFAULT_SIZE=3
WARM_POOL_MAX_SIZE=3
WARM_POOL_IDLE_TIMEOUT=30m

# ─── Live Context Mesh (NATS) ───
# `make dev` starts NATS via docker compose.
# Production: deploy NATS JetStream or use Synadia Cloud.
NATS_URL=nats://localhost:4222
NATS_AUTH_TOKEN=
NATS_MAX_AGE=168h

# ─── Secrets (HashiCorp Vault — optional) ───
# Only needed if you want real secret injection into environments.
# `make dev` starts Vault in dev mode via docker compose.
# Production: deploy Vault with real storage backend.
VAULT_ADDR=https://vault.yourdomain.com:8200
VAULT_TOKEN=hvs.xxxxxxxxxxxx

# ─── GitHub App ───
# 1. https://github.com/settings/apps/new
# 2. Webhook URL: {API_URL}/api/v1/webhooks/github
#    For local dev: use smee.io proxy (see scripts/dev-setup.sh)
# 3. Webhook secret: openssl rand -hex 32
# 4. Permissions: Contents (Read), Metadata (Read)
# 5. Events: Push, Create, Delete, Installation
GITHUB_APP_ID=123456
GITHUB_APP_WEBHOOK_SECRET=your_64char_hex_secret

# ─── Agent Binary ───
# URL where Hetzner servers download gradient-agent on first boot.
# Build: make build-agent-linux
# Local dev: http://localhost:6767/agent/gradient-agent (served by API)
# Production: GitHub Releases, S3, or any public URL.
AGENT_DOWNLOAD_URL=https://github.com/yourorg/gradient/releases/download/v0.1.0/gradient-agent-linux-amd64

# ─── MCP Server ───
MCP_SERVER_PORT=8081

# ─── Logging ───
LOG_LEVEL=info
