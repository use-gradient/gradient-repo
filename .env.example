# ═══════════════════════════════════════════════════════════════
# Gradient API — Environment Configuration
# Copy this file: cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# ── Server ─────────────────────────────────────────────────────
PORT=6767
ENV=development
API_URL=https://api.usegradient.dev

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=postgres://user:pass@localhost:5432/gradient?sslmode=disable

# ── Clerk Auth ─────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_JWKS_URL=https://your-clerk-instance.clerk.accounts.dev/.well-known/jwks.json
# CLERK_PEM_PUBLIC_KEY=  # Optional: static PEM key (alternative to JWKS)

# ── JWT Signing ────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-for-cli-tokens

# ── Stripe Billing ─────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_SMALL_ID=price_...
STRIPE_PRICE_MEDIUM_ID=price_...
STRIPE_PRICE_LARGE_ID=price_...
STRIPE_PRICE_GPU_ID=price_...

# ── Hetzner Cloud (primary provider) ──────────────────────────
HETZNER_API_TOKEN=
HETZNER_LOCATION=fsn1
HETZNER_SSH_KEY_IDS=             # Comma-separated IDs
HETZNER_SSH_PRIVATE_KEY=         # PEM-encoded (use \n for newlines)
# HETZNER_FIREWALL_ID=
# HETZNER_NETWORK_ID=
# HETZNER_IMAGE_ID=

# ── Container Registry ─────────────────────────────────────────
REGISTRY_URL=registry.example.com/gradient-envs
REGISTRY_USER=
REGISTRY_PASS=

# ── Agent ──────────────────────────────────────────────────────
AGENT_DOWNLOAD_URL=https://api.usegradient.dev/agent/gradient-agent

# ── GitHub App (auto-fork) ─────────────────────────────────────
GITHUB_APP_ID=
GITHUB_APP_WEBHOOK_SECRET=

# ── GitHub OAuth (repo connect) ───────────────────────────────
# Create an OAuth app at https://github.com/settings/developers
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:6969/dashboard/integrations

# ── Linear Integration (agent tasks) ──────────────────────────
# Create an OAuth app at https://linear.app/settings/api
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
LINEAR_REDIRECT_URI=https://api.usegradient.dev/api/v1/integrations/linear/callback

# ── NATS (Live Context Mesh) ──────────────────────────────────
NATS_URL=nats://localhost:4222
# NATS_AUTH_TOKEN=
# NATS_MAX_AGE=168h

# ── Warm Pool ─────────────────────────────────────────────────
WARM_POOL_DEFAULT_SIZE=3
WARM_POOL_MAX_SIZE=3
# WARM_POOL_IDLE_TIMEOUT=30m

# ── MCP Server ────────────────────────────────────────────────
MCP_SERVER_PORT=8081

# ── Vault (optional secrets backend) ──────────────────────────
# VAULT_ADDR=http://localhost:8200
# VAULT_TOKEN=

# ── AWS (legacy — not used in MVP) ────────────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_AMI_ID=
# AWS_SECURITY_GROUP_ID=
# AWS_SUBNET_ID=
# AWS_KEY_PAIR_NAME=

# ── GCP (future — not used) ──────────────────────────────────
# GCP_PROJECT_ID=
# GCP_CREDENTIALS_PATH=
# GCP_REGION=us-west1

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=info
